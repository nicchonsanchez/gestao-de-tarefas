{
  "name": "@ktask/contracts",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./users": {
      "types": "./dist/users.d.ts",
      "import": "./dist/users.js"
    },
    "./organizations": {
      "types": "./dist/organizations.d.ts",
      "import": "./dist/organizations.js"
    },
    "./roles": {
      "types": "./dist/roles.d.ts",
      "import": "./dist/roles.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/auth.ts src/users.ts src/organizations.ts src/roles.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/auth.ts src/users.ts src/organizations.ts src/roles.ts --format esm,cjs --dts --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@ktask/config-eslint": "workspace:*",
    "@ktask/config-tsconfig": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
